# Choose your provider: deepseek | deepseek-dashscope | qwen | qwen-plus | glm | minimax
PROVIDER=qwen

# Proxy server port (default: 8080)
PROXY_PORT=8080

# API Keys - set the one(s) you need
DASHSCOPE_API_KEY=sk-your-dashscope-key     # For qwen, qwen-plus, deepseek-dashscope
DEEPSEEK_API_KEY=sk-your-deepseek-key       # For deepseek
GLM_API_KEY=your-glm-key                    # For glm
MINIMAX_API_KEY=your-minimax-key            # For minimax
