# Choose your provider: deepseek | deepseek-dashscope | qwen | qwen-plus | glm | minimax | kimi
PROVIDER=qwen

# Proxy server port (default: 8080)
PROXY_PORT=8080

# API Keys - set the one(s) you need
DASHSCOPE_API_KEY=your-dashscope-key     # For qwen, qwen-plus, deepseek-dashscope
DEEPSEEK_API_KEY=your-deepseek-key       # For deepseek
GLM_API_KEY=your-glm-key                    # For glm
MINIMAX_API_KEY=your-minimax-key            # For minimax
KIMI_API_KEY=your-kimi-key               # For Kimi

# Optional Kimi overrides
KIMI_ANTHROPIC_MODEL=kimi-k2.5
